# ── Flutter / Dart ────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.dart_snapshots

# ── Generated Files ───────────────────────────────────────
*.g.dart
*.freezed.dart
*.mocks.dart

# ── Android ───────────────────────────────────────────────
android/.gradle/
android/local.properties
android/key.properties          # ⚠️ signing keys — never commit
android/*.jks                   # ⚠️ keystore files
android/app/debug/
android/app/release/
android/app/profile/
**/android/gradle-wrapper.jar

# ── iOS ───────────────────────────────────────────────────
ios/.symlinks/
ios/Pods/
ios/Podfile.lock
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig

# ── macOS ─────────────────────────────────────────────────
macos/.symlinks/
macos/Pods/
macos/Podfile.lock

# ── Linux / Windows ───────────────────────────────────────
linux/flutter/generated_plugin_registrant.cc
linux/flutter/generated_plugin_registrant.h
linux/flutter/generated_plugins.cmake
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake

# ── Web ───────────────────────────────────────────────────
web/flutter_service_worker.js
web/flutter.js

# ── VS Code ───────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# ── IDEs ──────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.fleet/

# ── OS Files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Environment & Secrets ────────────────────────────────
.env
.env.*
secrets.dart
google-services.json            # ⚠️ if you add Firebase later
GoogleService-Info.plist        # ⚠️ if you add Firebase later

# ── SQLite DB (local device data) ────────────────────────
*.db
*.db-journal
*.db-shm
*.db-wal

# ── Scanned Card Images (local device files) ─────────────
assets/scanned/
uploads/

# ── Logs & Reports ───────────────────────────────────────
*.log
coverage/
test/reports/